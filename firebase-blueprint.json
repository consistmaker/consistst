{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "currentLadderStage": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Intention": {
      "title": "Intention",
      "description": "Implementation Intentions (Jika X -> Maka Y)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "when": { "type": "string", "enum": ["PAGI", "SIANG", "SORE", "MALAM", "BURNOUT"] },
        "trigger": { "type": "string" },
        "response": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "when", "trigger", "response"]
    },
    "DailyBlock": {
      "title": "DailyBlock",
      "description": "Daily system time blocks",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "char": { "type": "string" },
        "time": { "type": "string" },
        "name": { "type": "string" },
        "tasks": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name"]
    },
    "WeeklyReview": {
      "title": "WeeklyReview",
      "description": "Weekly reflection and planning",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "q1": { "type": "string" },
        "q2": { "type": "string" },
        "q3": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "date"]
    },
    "Reframe": {
      "title": "Reframe",
      "description": "Mindset reframing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "old": { "type": "string" },
        "new": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "old", "new"]
    },
    "Tracker": {
      "title": "Tracker",
      "description": "Habit and progress tracker",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "history": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name"]
    },
    "QuickTask": {
      "title": "QuickTask",
      "description": "Urgent tasks or to-dos",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "text", "completed"]
    },
    "dailyStats": {
      "title": "DailyStats",
      "description": "Daily productivity statistics",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "date": { "type": "string" },
        "mainCompleted": { "type": "number" },
        "mainTotal": { "type": "number" },
        "quickCompleted": { "type": "number" }
      },
      "required": ["uid", "date"]
    },
    "FocusGoal": {
      "title": "FocusGoal",
      "description": "Daily deep work goals",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "dailyMinutes": { "type": "number" }
      },
      "required": ["uid", "dailyMinutes"]
    },
    "FocusSession": {
      "title": "FocusSession",
      "description": "Completed deep work sessions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "duration": { "type": "number" },
        "type": { "type": "string", "enum": ["work", "break"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "duration", "type"]
    },
    "FocusSettings": {
      "title": "FocusSettings",
      "description": "User focus preferences and blocklist",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "blocklist": { "type": "array", "items": { "type": "string" } },
        "workDuration": { "type": "number" },
        "breakDuration": { "type": "number" }
      },
      "required": ["uid"]
    },
    "Reward": {
      "title": "Reward",
      "description": "Customizable daily rewards for productivity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "text"]
    },
    "Mistake": {
      "title": "Mistake",
      "description": "Tracked mistakes and bad habits with penalty scores",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "description": { "type": "string" },
        "score": { "type": "number" },
        "date": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "description", "score", "date"]
    },
    "LadderItem": {
      "title": "LadderItem",
      "description": "Income projection stages",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "stageNum": { "type": "string" },
        "stageName": { "type": "string" },
        "skill": { "type": "string" },
        "income": { "type": "string" }
      },
      "required": ["uid", "stageName"]
    },
    "PinnedAction": {
      "title": "PinnedAction",
      "description": "Crucial daily or weekly focus actions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["daily", "weekly"] },
        "completed": { "type": "boolean" },
        "lastCompletedDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "text", "type"]
    },
    "Note": {
      "title": "Note",
      "description": "Personal notes and ideas",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "content": { "type": "string" },
        "color": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "content"]
    },
    "MatrixItem": {
      "title": "MatrixItem",
      "description": "Covey Matrix items for prioritization",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "quadrant": { "type": "string", "enum": ["q1", "q2", "q3", "q4"] },
        "text": { "type": "string" }
      },
      "required": ["uid", "quadrant", "text"]
    },
    "TriggerStep": {
      "title": "TriggerStep",
      "description": "Steps for trigger protocols",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "num": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" }
      },
      "required": ["uid", "num", "title"]
    },
    "ThemeSettings": {
      "title": "ThemeSettings",
      "description": "User theme customization",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "accentColor": { "type": "string" },
        "fontFamily": { "type": "string" }
      },
      "required": ["uid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/intentions/{intentionId}": {
      "schema": "Intention",
      "description": "User specific implementation intentions"
    },
    "/dailyBlocks/{blockId}": {
      "schema": "DailyBlock",
      "description": "User specific daily system blocks"
    },
    "/weeklyReviews/{reviewId}": {
      "schema": "WeeklyReview",
      "description": "User specific weekly reviews"
    },
    "/reframes/{reframeId}": {
      "schema": "Reframe",
      "description": "User specific mindset reframes"
    },
    "/trackers/{trackerId}": {
      "schema": "Tracker",
      "description": "User specific progress trackers"
    },
    "/quickTasks/{taskId}": {
      "schema": "QuickTask",
      "description": "User specific quick tasks"
    },
    "/dailyStats/{statId}": {
      "schema": "DailyStats",
      "description": "User specific daily productivity stats"
    },
    "/focusGoals/{goalId}": {
      "schema": "FocusGoal",
      "description": "User specific focus goals"
    },
    "/focusSessions/{sessionId}": {
      "schema": "FocusSession",
      "description": "User specific focus sessions"
    },
    "/focusSettings/{settingId}": {
      "schema": "FocusSettings",
      "description": "User specific focus settings"
    },
    "/rewards/{rewardId}": {
      "schema": "Reward",
      "description": "User specific customizable rewards"
    },
    "/mistakes/{mistakeId}": {
      "schema": "Mistake",
      "description": "User specific tracked mistakes"
    },
    "/ladder/{itemId}": {
      "schema": "LadderItem",
      "description": "User specific income ladder stages"
    },
    "/pinnedActions/{actionId}": {
      "schema": "PinnedAction",
      "description": "User specific pinned focus actions"
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "User specific personal notes"
    },
    "/matrixItems/{itemId}": {
      "schema": "MatrixItem",
      "description": "User specific Covey Matrix items"
    },
    "/triggerSteps/{stepId}": {
      "schema": "TriggerStep",
      "description": "User specific trigger protocol steps"
    },
    "/themeSettings/{userId}": {
      "schema": "ThemeSettings",
      "description": "User specific theme settings"
    }
  }
}
